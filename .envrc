# Load direnv's mamba functions
source "/home/earnest/.config/direnv/lib/use_mamba.sh"

# Activate the specific mamba environment for this project
# Name derived & sanitized from project folder by setup script
use_mamba "simple_rl"

# --- Terminal / terminfo fixes (Kitty + conda/mamba envs) ---
# Problem: Kitty sets TERM=xterm-kitty. Some conda envs export TERMINFO as an empty string
# or ship ncurses/terminfo that cannot read the system database, which breaks tools like 'clear'.

# 1) Avoid the broken state where TERMINFO is exported as an empty string.
unset TERMINFO

# 2) Give ncurses a sensible search path. Put the env first; then system; then kitty.
export TERMINFO_DIRS="${CONDA_PREFIX}/share/terminfo:/usr/share/terminfo:/usr/lib64/kitty/terminfo:/usr/lib/kitty/terminfo"

# 3) Optional: ensure xterm-kitty terminfo exists inside the env (helps ncurses tools shipped in the env).
#    Do not use kitty kittens here (names vary by kitty version). Use infocmp/tic instead.
if [ "${TERM-}" = "xterm-kitty" ] && [ -n "${CONDA_PREFIX-}" ] && [ -d "${CONDA_PREFIX}/share/terminfo" ]; then
  if [ ! -f "${CONDA_PREFIX}/share/terminfo/x/xterm-kitty" ]; then
    _INF="$(command -v infocmp || true)"; _TIC="$(command -v tic || true)";
    [ -x /usr/bin/infocmp ] && _INF=/usr/bin/infocmp; [ -x /usr/bin/tic ] && _TIC=/usr/bin/tic;
    if [ -n "$_INF" ] && [ -n "$_TIC" ]; then
      "$_INF" -x xterm-kitty 2>/dev/null | "$_TIC" -x -o "${CONDA_PREFIX}/share/terminfo" /dev/stdin >/dev/null 2>&1 || true
    fi
    unset _INF _TIC
  fi
fi

# 4) Hard fallback: override conda's broken 'clear' with the system one, in this directory only.
# Note: PATH_add is provided by direnv *only while evaluating .envrc*, not in an interactive shell.
if [ "${TERM-}" = "xterm-kitty" ]; then
  mkdir -p .direnv/bin
  if [ ! -x .direnv/bin/clear ]; then
    cat > .direnv/bin/clear <<'EOF'
#!/usr/bin/env bash
exec /usr/bin/clear "$@"
EOF
    chmod +x .direnv/bin/clear
  fi
  PATH_add .direnv/bin
fi

# Optional: Add other project-specific environment variables below

# Suppress pip restriction *only* while inside this directory
export PIP_REQUIRE_VIRTUALENV=
